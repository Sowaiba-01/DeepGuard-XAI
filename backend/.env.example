# ============================================
# DeepGuard AI Backend - Environment Variables
# ============================================

# HuggingFace
HF_TOKEN=your_huggingface_token_here
HF_DATASET_REPO=your-username/deepguard-dataset

# Model paths (relative to backend/)
DETECTION_MODEL_PATH=models/efficientnet_b4_ff++.pth
SIMSWAP_MODEL_PATH=models/simswap/

# Device (cpu or cuda)
DEVICE=cpu

# API settings
ALLOWED_ORIGINS=http://localhost:3000
MAX_FILE_SIZE_MB=50
